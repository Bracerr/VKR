# Корневой файл секретов для VKR (скопируйте: cp .env.example .env и заполните для прод).
# Docker Compose подставляет переменные при запуске из корня репозитория:
#   docker compose --env-file .env -f auth-service/docker-compose.yaml up -d
# или: make test-up / make prod-up (Makefile подхватывает .env, если файл есть).

# --- PostgreSQL (пароли БД; пользователи/имена БД в compose остаются фиксированными) ---
PG_AUTH_PASSWORD=auth
PG_WH_PASSWORD=wh
PG_SED_PASSWORD=sed
PG_PROD_PASSWORD=prod
PG_PROC_PASSWORD=proc
PG_SALES_PASSWORD=sales
PG_TRACE_PASSWORD=trace

# --- MinIO (стек sed-service / e2e) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345

# --- Keycloak (dev / e2e) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- auth-service ---
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-me
AUTH_SERVICE_SECRET=e2e-service-secret
AUTH_TEST_SECRET=e2e-test-secret
AUTH_STATE_COOKIE_SECRET=0123456789abcdef0123456789abcdef
AUTH_BOOTSTRAP_SUPERADMIN_PASSWORD=superadmin

# --- warehouse-service (X-Service-Secret; общий для sed/production/procurement/sales → warehouse) ---
WAREHOUSE_SERVICE_SECRET=sed-e2e-wh-secret

# --- traceability (ingest + вызовы из warehouse в e2e) ---
TRACE_INGEST_SECRET=e2e-trace-secret
TRACEABILITY_SECRET=e2e-trace-secret

# --- Доменные сервисы ↔ SED (callback verify: значение в сервисе = секрет в sed) ---
SED_CALLBACK_PRODUCTION_SECRET=e2e-prod-callback-secret
SED_CALLBACK_PROCUREMENT_SECRET=e2e-proc-callback-secret
SED_CALLBACK_SALES_SECRET=e2e-sales-callback-secret

# --- публичные URL при доступе через prod-gateway (внешний :52565 → внутр. :5656) ---
# KEYCLOAK_PUBLIC_URL=http://85.236.191.21:52565
# API_PUBLIC_URL=http://85.236.191.21:52565
# FRONTEND_URL=http://85.236.191.21:3000
# За prod-gateway добавьте для Keycloak (issuer/редиректы за reverse proxy):
# KC_PROXY=edge
