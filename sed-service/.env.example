# Для Docker из корня VKR: секреты в `VKR/.env` (см. `VKR/.env.example`). Ниже — пример для локального `go run`.

DB_DSN=postgres://sed:sed@localhost:5434/sed?sslmode=disable
WAREHOUSE_SERVICE_SECRET=change-me-shared-with-warehouse

# Опционально: callback в production-service после подписи документа (тот же секрет, что SED_CALLBACK_VERIFY_SECRET у production)
PRODUCTION_CALLBACK_URL=http://localhost:8092
PRODUCTION_CALLBACK_SECRET=change-me-shared-with-production-callback

# Опционально: callback в procurement-service после подписи документа (тот же секрет, что SED_CALLBACK_VERIFY_SECRET у procurement)
PROCUREMENT_CALLBACK_URL=http://localhost:8093
PROCUREMENT_CALLBACK_SECRET=change-me-shared-with-procurement-callback

# Опционально: callback в sales-service после подписи документа (тот же секрет, что SED_CALLBACK_VERIFY_SECRET у sales)
SALES_CALLBACK_URL=http://localhost:8094
SALES_CALLBACK_SECRET=change-me-shared-with-sales-callback
