# Для `docker compose` из корня VKR используйте общий файл секретов: `VKR/.env` (шаблон `VKR/.env.example`).
# Ниже — пример для локального `go run` из каталога auth-service (переменные те же по смыслу).

# В `.env` оставляем только чувствительные значения.
# Остальные настройки (URL, realm, client_id, флаги, лимиты и т.д.) лежат в YAML-конфиге:
# - `configs/docker.yaml` (для docker compose)
# - `configs/local.yaml` (для локального запуска)

# PostgreSQL (секрет, т.к. содержит пароль)
DB_DSN=postgres://auth:auth@localhost:5432/auth?sslmode=disable

# Keycloak (секреты)
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# API секреты
SERVICE_SECRET=service-secret-change-me
TEST_SECRET=test-secret-change-me
STATE_COOKIE_SECRET=32-byte-minimum-secret-key-here!!

# Bootstrap superadmin (пароль — секрет)
BOOTSTRAP_SUPERADMIN_PASSWORD=superadmin
